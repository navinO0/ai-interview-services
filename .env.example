# Server Configuration
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/interview_coach

# Cache & Jobs (Redis)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=generate-a-long-random-string

# AI Providers (Choose one or multiple)
AI_PROVIDER=ollama # Options: ollama, openai, anthropic, gemini

# Ollama (Local AI)
OLLAMA_URL=http://localhost:11434
MODEL_NAME=phi3:mini

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=...
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro

# OAuth (Optional)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Feature Flags
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=...
ALLOW_DIRECT_AI=true
LOG_AI_PROMPTS=true
LOG_DB_QUERIES=true
