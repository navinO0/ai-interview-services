
# ====================================================================
#  AI Interview Coach — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ====================================================================

# --------------------------------------------------------------------
# Server
# --------------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
SESSION_SECRET=your-session-secret-here

# --------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# --------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/interview_coach

# --------------------------------------------------------------------
# Cache, Queue & PubSub (Redis)
# Used by: BullMQ jobs, Socket.io adapter, rate limiting
# --------------------------------------------------------------------
ENABLE_REDIS=true
REDIS_URL=redis://localhost:6379
REDIS_INSIGHT_URL=http://localhost:5540

# --------------------------------------------------------------------
# Security
# --------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-long-random-string

# --------------------------------------------------------------------
# AI Providers
# Set AI_PROVIDER to the provider you want to use by default.
# Options: ollama | openai | anthropic | gemini
# Users can override per-session from the Settings → AI Intelligence tab.
# --------------------------------------------------------------------
AI_PROVIDER=ollama

# --- Ollama (Local — default, no API key needed) ---
OLLAMA_URL=http://localhost:11434
MODEL_NAME=phi3:mini

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# --- Google Gemini ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# --------------------------------------------------------------------
# OAuth (Optional — for social login)
# --------------------------------------------------------------------
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# --------------------------------------------------------------------
# Kafka / Redpanda (Event streaming for transcript logging)
# Default port 19092 = Redpanda internal listener in docker-compose
# --------------------------------------------------------------------
ENABLE_KAFKA=false
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=interview-coach-api
KAFKA_CONSOLE_URL=http://localhost:8080

# --- Remote Reachability (via Nginx/Tunnel) ---
# Set these to your Cloudflare domain if you want Kafka reachable from the internet.
# KAFKA_ADVERTISED_ADDR=broker.navin.lol:443
# PANDAPROXY_ADVERTISED_ADDR=kafka-api.navin.lol:443

# --------------------------------------------------------------------
# Real-time / WebSockets (Socket.io)
# Comma-separate multiple origins for local + production.
# Must include your Cloudflare domain(s) so Socket.io accepts connections.
# --------------------------------------------------------------------
SOCKET_CORS_ORIGIN=http://localhost:3000,https://navin.lol,https://app.navin.lol
ENABLE_SOCKET=false

# --------------------------------------------------------------------
# Feature Flags
# --------------------------------------------------------------------
# Allow direct Ollama proxy requests through the backend (advanced/debug)
ALLOW_DIRECT_AI=true

# Web search augmentation for richer AI answers (needs Tavily key)
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=tvly-...

# Debug logging (disable in production for performance)
LOG_AI_PROMPTS=true
LOG_DB_QUERIES=false

# --------------------------------------------------------------------
# Sentry Monitoring & Error Tracking
# --------------------------------------------------------------------
SENTRY_DSN=
SENTRY_DASHBOARD_URL=https://sentry.io/organizations/your-org/projects/your-project/
