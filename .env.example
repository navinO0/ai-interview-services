
# ====================================================================
#  AI Interview Coach — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ====================================================================

# --------------------------------------------------------------------
# Server
# --------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# --------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# --------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/interview_coach

# --------------------------------------------------------------------
# Cache, Queue & PubSub (Redis)
# Used by: BullMQ jobs, Socket.io adapter, dashboard response caching
# --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------------------------------
# Security
# --------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-long-random-string

# --------------------------------------------------------------------
# AI Providers
# Set AI_PROVIDER to the provider you want to use by default.
# Options: ollama | openai | anthropic | gemini
# Users can override per-session from the Settings → AI Intelligence tab.
# --------------------------------------------------------------------
AI_PROVIDER=ollama

# --- Ollama (Local — default, no API key needed) ---
OLLAMA_URL=http://localhost:11434
MODEL_NAME=phi3:mini

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# --- Google Gemini ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# --------------------------------------------------------------------
# OAuth (Optional — for social login)
# --------------------------------------------------------------------
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# --------------------------------------------------------------------
# Kafka / Redpanda (Event streaming for transcript logging)
# Default port 19092 = Redpanda internal listener in docker-compose
# --------------------------------------------------------------------
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=interview-coach

# --------------------------------------------------------------------
# Real-time / WebSockets (Socket.io)
# SOCKET_CORS_ORIGIN must match the frontend URL
# --------------------------------------------------------------------
SOCKET_CORS_ORIGIN=http://localhost:3000

# --------------------------------------------------------------------
# Feature Flags
# --------------------------------------------------------------------
# Allow direct Ollama proxy requests through the backend (advanced/debug)
ALLOW_DIRECT_AI=true

# Web search augmentation for richer AI answers (needs Tavily key)
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=tvly-...

# Debug logging (disable in production for performance)
LOG_AI_PROMPTS=true
LOG_DB_QUERIES=false
